{
  "name": "provin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --hostname localhost --port 3040",
    "dev:stable": "CHOKIDAR_USEPOLLING=1 WATCHPACK_POLLING=true next dev --hostname localhost --port 3001",
    "build": "next build",
    "start": "next start",
    "iriss:restore-backup": "node scripts/iriss-restore-backup.mjs",
    "preview": "next start --hostname localhost --port 3020",
    "preview:restart": "sh -c 'lsof -ti tcp:3020 | xargs kill -9 2>/dev/null || true; rm -rf .next && npm run build && npm run preview'",
    "lint": "next lint",
    "screenshot:mobile": "node scripts/mobile-screenshot.mjs",
    "screenshot:demo-mobile": "node scripts/demo-mobile-preview.mjs",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe"
  },
  "overrides": {
    "glob": "^13.0.6"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "archiver": "^7.0.1",
    "framer-motion": "^11.18.2",
    "lenis": "^1.3.21",
    "lucide-react": "^0.468.0",
    "next": "^15.2.4",
    "next-intl": "^4.9.0",
    "nodemailer": "^6.10.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "stripe": "^17.7.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.2.4",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
