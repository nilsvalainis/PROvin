# Uzņēmuma rekvizīti (distances līgums, GDPR, Stripe — jāsaskan ar konta īpašnieku)
# SDV: parasti Vārds Uzvārds + personas kods kā reģ. nr. | IK: piem. „IK PROVIN” + UR numurs
# Stripe: verifikācijā — SDV dokumenti; Dashboard „Public business” — PROVIN.LV; kājene — īstais vārds (saskan ar kontu)
# Bankas izraksts: bieži STRIPE* PROVIN.LV
# Opcionāli: publiskais zīmols kājenē (noklusējums PROVIN.LV)
# NEXT_PUBLIC_COMPANY_PUBLIC_BRAND=PROVIN.LV
NEXT_PUBLIC_COMPANY_LEGAL_NAME=
NEXT_PUBLIC_COMPANY_REG_NO=
NEXT_PUBLIC_COMPANY_LEGAL_ADDRESS=

# Rēķins — opcionāli: pilns PVN kājenes teksts (noklusējums — SDV / PVN likuma 3. pants)
# NEXT_PUBLIC_INVOICE_PVN_DISCLAIMER=
# PRV-YYYY-XXXX secība: invoice-year-sequence.json (tajā pašā mapē kā pasūtījumu JSON)

# Public site URL (bez slīpsvītras) — Stripe redirectiem, sitemap, SEO
# Lokāli: http://localhost:3000  |  Produkcija (piem. Vercel + provin.lv): https://provin.lv
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
# Produkcijā: Dashboard → Webhooks → signing secret. Lokāli: `stripe listen` izdrukā whsec_… un ieliec šeit.
STRIPE_WEBHOOK_SECRET=whsec_...

# Statistika (/admin/statistika) — ārējs analīzes panelis (https). Piemēram Plausible „share” embed vai GA saite.
# NEXT_PUBLIC_ANALYTICS_DASHBOARD_URL=https://plausible.io/...
# NEXT_PUBLIC_ANALYTICS_EMBED_URL=https://plausible.io/share/... (vai cits https iframe embed)

# Google Analytics 4 — mērījuma ID no GA (gtag.js). EEZ: Consent Mode / saskaņot ar CookieConsent un privātumu.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Admin panelis (/admin)
# Lokāli (npm run dev): nav obligāti — izmantoti droši noklusējumi (tikai izstrāde, ne produkcija).
# Vercel / produkcija: obligāti visi trīs — ADMIN_SECRET ≥ 16 rakstzīmes (nejauša virkne).
ADMIN_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Groq (OpenAI-saderīgs Chat API) — admin ✨ gramatika (`llama-3.1-8b-instant`), sludinājuma analīze (`llama-3.1-70b-versatile`).
# Atslēga: https://console.groq.com/keys — Lokāli: `.env.local`; pēc pievienošanas restartē `npm run dev`.
# Vercel: Settings → Environment Variables → GROQ_API_KEY.
GROQ_API_KEY=

# Admin melnraksts (JSON): VIN / sludinājums / piezīmes + avotu bloki + IRISS. Portfeļa PDF paliek IndexedDB.
# Noklusējums: .data/admin-order-drafts/ projekta saknē (piem. VPS + `next start`). Izslēgt: ADMIN_ORDER_DRAFT_DIR=off
# Vercel serverless: pastāvīgs disks parasti nav — vajadzīga ārēja glabātava (Redis/DB/Blob) vai izslēgt.
ADMIN_ORDER_DRAFT_DIR=

# Demo pasūtījumi /admin — noklusējums ieslēgts. Izslēgt: ADMIN_DEMO_ORDERS=0
ADMIN_DEMO_ORDERS=

# Admin alerts — iestatīt vismaz vienu kanālu
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Transakciju e-pasti — tikai Google Workspace SMTP (bez Resend/Mailgun).
# Obligāti aizpildīt SMTP_USER + SMTP_PASS, lai sūtītu: apmaksas apstiprinājumu, „audits gatavs”, u.c.
# Google Account → Security → 2-Step Verification → App passwords → izveido parole „Mail” / „Vercel”.
# SMTP_USER = pilna Workspace adrese (piem. info@provin.lv); SMTP_PASS = 16 rakstu app password.
# Produkcijā: Vercel → Project → Settings → Environment Variables (ne tikai lokālais .env).
# SMTP_FROM (opcionāli): jāsaskan ar Workspace atļauto sūtītāju/alias; noklusējums PROVIN <SMTP_USER>.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="PROVIN <info@provin.lv>"
SMTP_REPLY_TO=info@provin.lv
# /api/admin/notify-report-ready — pielikumu kopējais apjoms ~4 MB (`lib/notify-report-email-limits.ts`). Portfeli var nosūtīt no pasūtījuma darba zonas vai ar failiem no pasūtījumu tabulas.
# Admin paziņojumi (jauns pasūtījums u.c.) — var būt tas pats info@ vai atsevišķs admin@.
ADMIN_NOTIFY_EMAIL=

# WhatsApp — pilns https://wa.me/371XXXXXXXX (noklusējums: lib/contact.ts)
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/37120420539

# Vispārīgā saziņa (mailto; adrese lapā netiek drukāta). Produkcijā: info@provin.lv; Reply-To, ja SMTP_REPLY_TO tukšs.
NEXT_PUBLIC_CONTACT_EMAIL=info@provin.lv

# IRISS / Perekupa Dienasgrāmata — sociālie tīkli (pilnas https:// saites; tukšs = noklusējums no `lib/iriss-social-defaults.ts`)
NEXT_PUBLIC_IRISS_TIKTOK_URL=
NEXT_PUBLIC_IRISS_YOUTUBE_URL=
NEXT_PUBLIC_IRISS_INSTAGRAM_URL=
