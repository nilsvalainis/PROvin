# Public site URL (bez slīpsvītras) — Stripe redirectiem, sitemap, SEO
# Lokāli: http://localhost:3000  |  Produkcija (piem. Vercel + provin.lv): https://provin.lv
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin panelis (/admin) — garš nejaušs ADMIN_SECRET; lietotājvārds un parole
ADMIN_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# 1 = parauga pasūtījumi admin sarakstā (izstrāde / priekšskatījums)
ADMIN_DEMO_ORDERS=

# Admin alerts — iestatīt vismaz vienu kanālu
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: e-pasts caur Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL="PROVIN <orders@provin.lv>"
ADMIN_NOTIFY_EMAIL=

# WhatsApp — pilns https://wa.me/371XXXXXXXX (noklusējums: lib/contact.ts)
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/37120420539

# Vispārīgā saziņa (mailto; adrese lapā netiek drukāta)
NEXT_PUBLIC_CONTACT_EMAIL=perekupadienasgramata@gmail.com

# IRISS / Perekupa Dienasgrāmata — sociālie tīkli (pilnas https:// saites)
NEXT_PUBLIC_IRISS_TIKTOK_URL=
NEXT_PUBLIC_IRISS_YOUTUBE_URL=
NEXT_PUBLIC_IRISS_INSTAGRAM_URL=
