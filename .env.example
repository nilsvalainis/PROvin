# Uzņēmuma rekvizīti (distances līgums, GDPR, Stripe — jāsaskan ar konta īpašnieku)
# SDV: parasti Vārds Uzvārds + personas kods kā reģ. nr. | IK: piem. „IK PROVIN” + UR numurs
# Stripe: verifikācijā — SDV dokumenti; Dashboard „Public business” — PROVIN.LV; kājene — īstais vārds (saskan ar kontu)
# Bankas izraksts: bieži STRIPE* PROVIN.LV
# Opcionāli: publiskais zīmols kājenē (noklusējums PROVIN.LV)
# NEXT_PUBLIC_COMPANY_PUBLIC_BRAND=PROVIN.LV
NEXT_PUBLIC_COMPANY_LEGAL_NAME=
NEXT_PUBLIC_COMPANY_REG_NO=
NEXT_PUBLIC_COMPANY_LEGAL_ADDRESS=

# Rēķins — opcionāli: pilns PVN kājenes teksts (noklusējums — SDV / PVN likuma 3. pants)
# NEXT_PUBLIC_INVOICE_PVN_DISCLAIMER=
# PRV-YYYY-XXXX secība: invoice-year-sequence.json (tajā pašā mapē kā pasūtījumu JSON)

# Public site URL — obligāti ar shēmu (https://…), bez slīpsvītras beigās; SEO metadataBase / sitemap
# Lokāli: http://localhost:3000  |  Produkcija: https://provin.lv vai https://www.provin.lv
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PROVIN SELECT — pēc noklusējuma redzams. Pilnībā slēpt: 0 vai false.
# NEXT_PUBLIC_PROVIN_SELECT_PUBLIC=0

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
# Produkcijā: Dashboard → Webhooks → signing secret. Lokāli: `stripe listen` izdrukā whsec_… un ieliec šeit.
STRIPE_WEBHOOK_SECRET=whsec_...

# Statistika (/admin/statistika) — ārējs analīzes panelis (https). Piemēram Plausible „share” embed vai GA saite.
# NEXT_PUBLIC_ANALYTICS_DASHBOARD_URL=https://plausible.io/...
# NEXT_PUBLIC_ANALYTICS_EMBED_URL=https://plausible.io/share/... (vai cits https iframe embed)

# Google Analytics 4 — mērījuma ID no GA (gtag.js). EEZ: Consent Mode / saskaņot ar CookieConsent un privātumu.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Admin panelis (/admin)
# Lokāli (npm run dev): nav obligāti — izmantoti droši noklusējumi (tikai izstrāde, ne produkcija).
# Vercel / produkcija: obligāti visi trīs — ADMIN_SECRET ≥ 16 rakstzīmes (nejauša virkne).
ADMIN_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Groq (OpenAI-saderīgs Chat API) — admin ✨ gramatika (`llama-3.1-8b-instant`), sludinājuma analīze (`llama-3.1-70b-versatile`).
# Atslēga: https://console.groq.com/keys — Lokāli: `.env.local`; pēc pievienošanas restartē `npm run dev`.
# Vercel: Settings → Environment Variables → GROQ_API_KEY.
GROQ_API_KEY=

# Admin melnraksts (JSON): VIN / sludinājums / piezīmes + avotu bloki + IRISS. Portfeļa PDF paliek IndexedDB.
# Noklusējums: .data/admin-order-drafts/ projekta saknē (piem. VPS + `next start`). Izslēgt: ADMIN_ORDER_DRAFT_DIR=off
# Vercel serverless: pastāvīgs disks parasti nav — vajadzīga ārēja glabātava (Redis/DB/Blob) vai izslēgt.
# KRITISKI: produkcijā neizmanto /tmp vai "off", ja vajag atjaunošanu.
ADMIN_ORDER_DRAFT_DIR=
# (Opcionāli) Pasūtījumu melnrakstu JSON Vercel Blob — prefikss ar slīpsvītru beigās, piem. admin-order-drafts/. Nepieciešams BLOB_READ_WRITE_TOKEN. Eksports `/api/admin/orders/export` nolasa gan FS, gan šo prefiksu.
ADMIN_ORDER_DRAFT_BLOB_PREFIX=

# PROVIN SELECT konsultāciju drafti (JSON). Noklusējums: .data/admin-consultation-drafts.
# KRITISKI: produkcijā neizmanto /tmp vai "off", ja vajag atjaunošanu.
ADMIN_CONSULTATION_DRAFT_DIR=

# IRISS admin — PASŪTĪJUMI (JSON). Lokāli / next start: .data/iriss-pasutijumi. Vercel: Vercel Blob (privāti), ja ir BLOB_READ_WRITE_TOKEN; ja nav token un nav šī ceļa — melnraksts izslēgts. ADMIN_IRISS_PASUTIJUMI_DIR pārraksta uz disku (piem. montēts volūms). Izslēgt: ADMIN_IRISS_PASUTIJUMI_DIR=0
ADMIN_IRISS_PASUTIJUMI_DIR=
# Vercel Blob (read-write) — Storage → Blob → Connect to Project; lokāliem testiem: `vercel env pull`
BLOB_READ_WRITE_TOKEN=

# Ikdienas admin draft "restore point" backup cron:
# - vercel.json ieplānots katru dienu 02:00 UTC (`/api/cron/admin-drafts-daily-backup`)
# - obligāti ieliec drošu secret (Authorization: Bearer ...)
ADMIN_DRAFT_BACKUP_CRON_SECRET=
# Opcionāli Blob prefikss ikdienas snapshotiem (default: admin-daily-backups/)
ADMIN_DRAFT_DAILY_BACKUP_BLOB_PREFIX=

# IRISS "Sludinājumi" agregācija (jauna neatkarīga lapa /admin/iriss/sludinajumi).
# Storage noklusējums lokāli: .data/iriss-sludinajumi ; izslēgt: ADMIN_IRISS_LISTINGS_DIR=off
ADMIN_IRISS_LISTINGS_DIR=
# Opcionāli Blob prefikss (Vercel), piem. iriss-sludinajumi/
ADMIN_IRISS_LISTINGS_BLOB_PREFIX=
# Cron auth secret endpointam /api/cron/iriss-listings-daily-sync
ADMIN_IRISS_LISTINGS_CRON_SECRET=
# Opcionāli limits vienam sync ciklam (drošības iemesls)
IRISS_LISTINGS_MAX_SOURCES_PER_RUN=800
# Opcionāli timeout katra URL nolasīšanai (ms)
IRISS_LISTINGS_FETCH_TIMEOUT_MS=18000
#
# Login / autorizācijas dati pa platformām (ja avots prasa auth):
# Var lietot AUTH_HEADER (piem. Bearer ...) vai COOKIE (pilna Cookie header vērtība).
# Ieteicams iestatīt tikai vajadzīgajiem avotiem.
IRISS_LISTINGS_MOBILE_AUTH_HEADER=
IRISS_LISTINGS_MOBILE_COOKIE=
IRISS_LISTINGS_MOBILE_USER_AGENT=
IRISS_LISTINGS_AUTOBID_AUTH_HEADER=
IRISS_LISTINGS_AUTOBID_COOKIE=
IRISS_LISTINGS_AUTOBID_USER_AGENT=
IRISS_LISTINGS_OPENLINE_AUTH_HEADER=
IRISS_LISTINGS_OPENLINE_COOKIE=
IRISS_LISTINGS_OPENLINE_USER_AGENT=
IRISS_LISTINGS_AUTO1_AUTH_HEADER=
IRISS_LISTINGS_AUTO1_COOKIE=
IRISS_LISTINGS_AUTO1_USER_AGENT=

# Demo pasūtījumi /admin — noklusējums ieslēgts. Izslēgt: ADMIN_DEMO_ORDERS=0
ADMIN_DEMO_ORDERS=

# Admin alerts — iestatīt vismaz vienu kanālu
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Transakciju e-pasti — tikai Google Workspace SMTP (bez Resend/Mailgun).
# Obligāti aizpildīt SMTP_USER + SMTP_PASS, lai sūtītu: apmaksas apstiprinājumu, „audits gatavs”, u.c.
# Google Account → Security → 2-Step Verification → App passwords → izveido parole „Mail” / „Vercel”.
# SMTP_USER = pilna Workspace adrese (piem. info@provin.lv); SMTP_PASS = 16 rakstu app password.
# Produkcijā: Vercel → Project → Settings → Environment Variables (ne tikai lokālais .env).
# SMTP_FROM (opcionāli): jāsaskan ar Workspace atļauto sūtītāju/alias; noklusējums PROVIN <SMTP_USER>.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="PROVIN <info@provin.lv>"
SMTP_REPLY_TO=info@provin.lv
#
# E-pasta piegāde (Gmail „Mēstules”) — galvenokārt DNS + Workspace, ne kods:
# – Google Admin → Apps → Google Workspace → Gmail → Authenticate email: ieslēgt SPF/DKIM domēnam provin.lv (seko vednim).
# – SMTP_USER un SMTP_FROM jābūt tai pašai Workspace adresei (vai atļautam aliasam), lai DKIM paraksts sakristu.
# – DMARC: sākumā `v=DMARC1; p=none; rua=mailto:...` (uzraudzība), vēlāk `p=quarantine` vai `reject`.
# – Pirmais tests: nosūtīt uz citu pakalpojumu (ne Gmail), pārbaudīt „Show original” → SPF/DKIM/PASS.
# – Klientam: „Nav mēstule” + pievienot kontaktiem; vairāki identiski testi īsā laikā paši palielina spam score.
#
# /api/admin/notify-report-ready — pielikumu kopējais apjoms ~20 MB (`lib/notify-report-email-limits.ts`). Portfeli var nosūtīt no pasūtījuma darba zonas vai ar failiem no pasūtījumu tabulas.
# Jauns apmaksāts pasūtījums — e-pasts adminam (`checkout.session.completed` webhook; skat. DEPLOY.md arī `async_payment_succeeded`).
# Ja tukšs, bet SMTP_USER satur @ — paziņojums tiek sūtīts uz SMTP_USER (parasti info@provin.lv). Citādi iestatīt atsevišķu admin@.
ADMIN_NOTIFY_EMAIL=

# WhatsApp — pilns https://wa.me/371XXXXXXXX (noklusējums: lib/contact.ts)
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/37120420539

# Vispārīgā saziņa (mailto; adrese lapā netiek drukāta). Produkcijā: info@provin.lv; Reply-To, ja SMTP_REPLY_TO tukšs.
NEXT_PUBLIC_CONTACT_EMAIL=info@provin.lv

# IRISS / Perekupa Dienasgrāmata — sociālie tīkli (pilnas https:// saites; tukšs = noklusējums no `lib/iriss-social-defaults.ts`)
NEXT_PUBLIC_IRISS_TIKTOK_URL=
NEXT_PUBLIC_IRISS_YOUTUBE_URL=
NEXT_PUBLIC_IRISS_INSTAGRAM_URL=
